# Copy to .env.local and fill in. NEVER commit .env.local.
# The publishable/anon key is safe for the browser. Service-role key and the
# database password are SECRETS — server/cron only, never expose to the client,
# never paste into chat or commit to git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secrets (do not prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Meta / Instagram (Phase 2)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# Stripe (Phase 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
